    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@stripe/react-stripe-js": {
      "react": "^19.2.0",
      "react-dom": "^19.2.0"
